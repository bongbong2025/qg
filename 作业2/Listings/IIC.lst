  46          
  47          //SDA置1为非响应，置0为响应，且都将SCL先拉高后降低
  48          
  49          unsigned char IIC_WaitAck(void) //响应等待，判断主从机之间是否有响应
  50          {
  51   1              unsigned char tim = 0;
  52   1              IIC_SCL = 1;
  53   1              Delay10us(1);
  54   1              while(IIC_SDA)

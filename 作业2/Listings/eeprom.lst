  13   1              IIC_WaitAck();
  14   1              IIC_Stop();                     //关闭I2C总线
  15   1              Delayms(10);            //延时防止数据传输不完全
  16   1      }
  17          
  18          unsigned char eeprom_read_onebyte(unsigned char addr)
  19          {
  20   1              unsigned char temp = 0;
  21   1              
  22   1              IIC_Start();            //开启总线
  23   1              IIC_WriteByte(0xA0);//写入模式
  24   1              IIC_WaitAck();
  25   1              IIC_WriteByte(addr);//写入eeprom存储地址
  26   1              IIC_WaitAck();
  27   1              IIC_Start();            //重新开启总线，改变数据传输方向
  28   1              IIC_WriteByte(0xA1);//读取模式
  29   1              IIC_WaitAck();
  30   1              temp = IIC_ReadByte(0); //读取eeprom存储的数据
  31   1              IIC_Stop();                     //关闭总线
  32   1              return temp;            //返回eeprom中的数据

  67          void IIC_WriteByte(unsigned char dat)
  68          {
  69   1              unsigned char i;
  70   1              
  71   1              IIC_SCL = 0;
  72   1              for(i = 0; i < 8; i++)          //逐位写入数据
  73   1              {
  74   2                      if(dat &= 0x80) IIC_SDA = 1;
  75   2                      else IIC_SDA = 0;
  76   2                      dat <<= 1;                              //左移调整录入位次
  77   2                      IIC_SCL = 1;
  78   2                      Delay10us(1);
  79   2                      IIC_SCL = 0;                    //延时捕获电平变化
  80   2                      Delay10us(1);
  81   2              }
  82   1      }
  83          
  84          unsigned char IIC_ReadByte(unsigned char ack)
  85          {
  86   1              unsigned char i;
  87   1              unsigned char receive = 0;
  88   1              
  89   1              for(i = 0; i < 8; i++)          //逐位读取数据
  90   1              {
  91   2                      IIC_SCL = 0;
  92   2                      Delay10us(1);
  93   2                      IIC_SCL = 1;
  94   2                      Delay10us(1);
  95   2                      receive <<= 1;
  96   2                      if(IIC_SDA) receive++;
  97   2              }
  98   1              
  99   1              if(!ack) IIC_NotAck();
 100   1              else IIC_Ack();

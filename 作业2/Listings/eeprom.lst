   3          #include "Delay.h"
   4          
   5          void eeprom_write_onebyte(unsigned char addr, unsigned char dat)
   6          {
   7   1              IIC_Start();            //开启I2C总线
   8   1              IIC_WriteByte(0xA0);//写入模式
   9   1              IIC_WaitAck();
  10   1              IIC_WriteByte(addr);//写入eeprom的地址
  11   1              IIC_WaitAck();

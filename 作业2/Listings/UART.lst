   1          #include <REGX52.H>
   2          
   3          
   4          void Uart_Init(void)            
   5          {
   6   1              PCON |= 0x80;           //使能波特率倍速位SMOD
   7   1              SCON = 0x50;            //8位数据,可变波特率
   8   1              TMOD &= 0x0F;           //清除定时器1模式位
   9   1              TMOD |= 0x20;           //设定定时器1为8位自动重装方式
  10   1              TL1 = 0xF3;             //设定定时初值
  11   1              TH1 = 0xF3;             //设定定时器重装值
  12   1              ET1 = 0;                //禁止定时器1中断
  13   1              TR1 = 1;                //启动定时器1
  14   1              EA = 1;
  15   1              ES = 1;                 //使能中断
  16   1      }
  17          
  18          void UART_SendByte(unsigned char Byte)  //串口接收数据
  19          {
  20   1              SBUF = Byte;
  21   1              while(TI == 0);
  22   1              TI = 0;
  23   1      }


